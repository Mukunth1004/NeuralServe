APP_NAME=NeuralServe
APP_VERSION=1.0.0
APP_ENV=development
PORT=8000
LOG_LEVEL=INFO

# Model — uses distilbert-base-uncased-finetuned-sst-2-english by default (auto-downloads)
MODEL_NAME=distilbert-base-uncased-finetuned-sst-2-english
MODEL_PATH=./models/onnx
USE_ONNX=false
MAX_BATCH_SIZE=32
MAX_SEQUENCE_LENGTH=512

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/neuralserve

# Performance
WORKER_COUNT=4
